# Redis Configuration (for Bull Queue Worker)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

# CapSolver API (for CAPTCHA solving)
CAPSOLVER_API_KEY=your-capsolver-api-key-here

# Proxy Configuration (BrightData or Smartproxy)
PROXY_USERNAME=your-proxy-username
PROXY_PASSWORD=your-proxy-password
PROXY_SERVER=your-proxy-server.com
PROXY_PORT=22225

# Database (shared with backend)
DATABASE_PATH=../backend/database.sqlite

# Bot Configuration
MIN_DELAY_BETWEEN_ACCOUNTS=300000  # 5 minutes in milliseconds
MAX_DELAY_BETWEEN_ACCOUNTS=600000  # 10 minutes in milliseconds
MAX_RETRIES=3

# TikTok URLs
TIKTOK_SIGNUP_URL=https://www.tiktok.com/signup
